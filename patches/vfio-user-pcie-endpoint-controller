+  case QEPC_CTRL_OFF_MSIX_NUM:
+    if (val == 0 || val > 2048) {
+      trace_qepc_ctrl_write_msix_num_invalid(val);
+      return;
+    }
+    s->msix_num = (uint16_t)val;
